# Orchestrator configuration

# Optional Slack webhook URL for notifications.
# When set, Info+ messages are posted to Slack in addition to stderr.
# slack_webhook: "https://hooks.slack.com/services/YOUR/WEBHOOK/URL"

# Directory where task output (code, conversations, metadata) is stored.
# output_dir: "./tasks"

# Public base URL of the orchestrator web server. When set, the upload_image
# MCP tool is enabled — images are stored in tasks/<name>/images/ and served
# at <base_url>/tasks/<name>/images/<file>.
# base_url: "https://drella.example.com"

# Sandbox backend: "gjoll" (VMs) or "podman" (containers).
# Defaults to "gjoll". Use "podman" for faster local iteration.
# sandbox_backend: "gjoll"

# Gjoll backend settings (for VM-based sandboxes):
# Path to the gjoll .tf file for sandbox provisioning.
# - Local LLM + libvirt: gjoll/examples/fedora-libvirt.tf (gjoll proxy to host LM Studio/Ollama)
# - Vertex AI cloud: ./configs/sandbox.tf (edit project ID first)
# - Anthropic API cloud: configs/sandbox-anthropic-api.tf.example
# gjoll_env: "./configs/sandbox.tf"

# Podman backend settings (for container-based sandboxes):
# Container image to use for sandboxes.
# podman_image: "fedora:43"

# Agent backend: "opencode" (default) or "claude-code".
# agent_backend: "opencode"

# Local LLM API base URL (LM Studio or Ollama OpenAI-compatible endpoint).
# Default when omitted: http://127.0.0.1:1234/v1
# Set to empty string to use cloud Anthropic/Vertex instead.
# llm_base_url: "http://127.0.0.1:1234/v1"

# Model ID on the local API (OpenCode: passed as --model local/<id>).
# When omitted, the first model from <llm_base_url>/models is used.
# llm_model: "google/gemma-4-e4b"

# Path to Anthropic API key file (only when llm_base_url is disabled).
# Sign up at https://console.anthropic.com and save the key here.
# anthropic_key_file: "~/.anthropic/api_key"

# Repos the sandbox is allowed to open PRs against (supports wildcards).
# Requires gh CLI authentication on the host.
# allowed_repos:
#   - myorg/myrepo
#   - myorg/*

# Profile configuration. Profiles provide task-type-specific Claude
# configuration (CLAUDE.md, setup scripts, MCP servers, settings).
# Use --profile <name> on "task new" to apply a profile.
#
# GitHub repo containing profile directories (cloned via gh).
# profiles_repo: "myorg/profiles"
#
# Local directory override for development (takes precedence over profiles_repo).
# profiles_dir: ""

# Agent budget limits. Controls how much a single Claude session can spend.
# agent:
#   # Hard spending cap passed to `claude --max-budget-usd`. Claude stops when
#   # this limit is reached. Set to 0 or omit to disable.
#   max-budget-usd: 100
#   # Dashboard warning threshold — usage display turns orange when cost exceeds
#   # this value.
#   warn-budget-usd: 30
#   # Dashboard critical threshold — usage display turns red when cost exceeds
#   # this value.
#   critical-budget-usd: 50

# Daemon configuration for automatic PR comment polling.
# daemon:
#   # How often the daemon completes a full cycle across all PRs.
#   poll_interval: "60s"
#   # Only comments from these GitHub users trigger task continue.
#   allowed_commenters:
#     - myuser
#   # Tasks repo to monitor for new specs in in-progress/ (e.g. "myorg/tasks").
#   # When set, the daemon polls this repo for new spec files and spawns tasks.
#   # tasks_repo: "myorg/tasks"
