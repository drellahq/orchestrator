# Orchestrator configuration

# Optional Slack webhook URL for notifications.
# When set, Info+ messages are posted to Slack in addition to stderr.
# slack_webhook: "https://hooks.slack.com/services/YOUR/WEBHOOK/URL"

# Directory where task output (code, conversations, metadata) is stored.
# output_dir: "./tasks"

# Path to the gjoll .tf file for sandbox provisioning.
# Edit configs/sandbox.tf to set your Vertex AI project ID before use.
# gjoll_env: "./configs/sandbox.tf"

# Repos the sandbox is allowed to open PRs against (supports wildcards).
# Requires gh CLI authentication on the host.
# allowed_repos:
#   - myorg/myrepo
#   - myorg/*

# Directory containing agent role prompt files (default: "agents").
# Each file defines one agent role; the filename (minus .md) is the role ID.
# agents_dir: "./agents"

# Pipeline definitions. A pipeline is an ordered sequence of agent roles.
# The "default" pipeline is used unless overridden. If no pipelines are
# configured, a single "producer" step runs (backward-compatible behavior).
#
# The last step in a multi-step pipeline is treated as the reviewing role:
# it must produce a structured "VERDICT: pass" or "VERDICT: fail" line in
# its output. On failure, the orchestrator re-runs the pipeline from the
# first step with the reviewer's findings as feedback. This loop repeats
# until the reviewer passes or max_iterations is reached.
#
# max_iterations is configured on the last step and controls how many
# full pipeline cycles run before escalation (default: 3).
#
# pipelines:
#   default:
#     - role: producer
#     - role: validator
#       max_iterations: 3     # full pipeline cycles before escalation
#       handoff:
#         include_diff: true
#         include_prior_transcript: false
#         include_prior_summary: false

# Daemon configuration for automatic PR comment polling.
# daemon:
#   # How often the daemon completes a full cycle across all PRs.
#   poll_interval: "60s"
#   # Only comments from these GitHub users trigger task continue.
#   allowed_commenters:
#     - myuser
#   # Tasks repo to monitor for new specs in in-progress/ (e.g. "myorg/tasks").
#   # When set, the daemon polls this repo for new spec files and spawns tasks.
#   # tasks_repo: "myorg/tasks"
